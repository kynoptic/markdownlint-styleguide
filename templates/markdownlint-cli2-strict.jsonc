{
  // Strict configuration for markdownlint-styleguide
  // Inherits all rules from the strict preset
  "gitignore": true,
  "customRules": [
    "markdownlint-styleguide"
  ],
  "config": {
    "extends": "markdownlint-styleguide/strict-config.jsonc"
    // Add repo-specific overrides below this line
  }
}
